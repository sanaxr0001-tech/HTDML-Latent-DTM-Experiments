# Python bytecode / caches
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Build scratch — keep on disk, not in git
.superpowers/

# Dataset and model caches (populated at Task 7+)
data/
cache/

# Vendored FID precomputed stats — ignore all EXCEPT the sha-pinned BW Fashion-MNIST ref
vendor/dtm-replication/thrmlDenoising/fid/precomputed_stats/*
!vendor/dtm-replication/thrmlDenoising/fid/precomputed_stats/bw_fashion_mnist_train.npz

# Run outputs (smoke + full): JSON verdicts, report.md, and the fork-checkpoint work dir.  Generated
# artifacts — produced/transferred/reported on-box, not version-controlled here (git add -f a verdict
# if one ever needs committing).  (spec §6: the smoke json in particular is gitignored.)
results/
run_stage_c_smoke.json

# Stage-B resume checkpoints (RESUME_FROM): heavy artifacts gitignored; manifest.json stays committable
# for provenance (records the seed/config/data-hash/code-SHA a resumed Stage C ran against).
# NB **/ prefix so it matches checkpoints/ at ANY depth (e.g. experiments/exp2-cal-gate-fix/artifacts/
# checkpoints/), not just a repo-root checkpoints/ — the run's OUTDIR is nested.
**/checkpoints/**/*.eqx
**/checkpoints/**/*.npy
**/checkpoints/**/*.msgpack
**/checkpoints/**/*.yaml
**/checkpoints/**/autocorrelations.json
**/checkpoints/**/opt_counts.json
